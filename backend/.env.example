# Aero-Planer — backend (скопируйте в .env и заполните)
PORT=3001

# MySQL 8 — обязательно: сервер должен быть запущен на этом хосте/порту
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=ваш_пароль_mysql
DB_NAME=aero_planer

# JWT (для локальной разработки можно оставить как есть)
JWT_SECRET=dev-local-jwt-secret-change-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# URL фронтенда (Vite dev server)
CORS_ORIGIN=http://localhost:5173

NODE_ENV=development

# Опционально: ключ CheckWX для приоритетного метео-источника
# CHECKWX_API_KEY=
